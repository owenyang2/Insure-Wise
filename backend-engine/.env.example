# ─── IBM Watson ───────────────────────────────────────────────
WATSONX_API_KEY=your_watsonx_api_key_here
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

WDU_API_KEY=your_watson_document_understanding_key_here
WDU_URL=https://api.us-south.discovery.watson.cloud.ibm.com/instances/your_instance_id

IBM_NLP_API_KEY=your_ibm_nlp_key_here
IBM_NLP_URL=https://api.us-south.natural-language-understanding.watson.cloud.ibm.com/instances/your_instance_id

# ─── Aggregator API ───────────────────────────────────────────
# EverQuote Pro or Bindable — use whichever you sign up for
AGGREGATOR_PROVIDER=everquote
AGGREGATOR_API_KEY=your_aggregator_api_key_here
AGGREGATOR_URL=https://api.everquote.com/v1

# ─── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/insurance_agent

# ─── Redis (session state) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
